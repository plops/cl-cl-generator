;; --- Single-precision with-* convenience macros ---
(defmacro with-s-ocp-qp-dim ((var n) &body body)
  "Allocate HPIPM ocp_qp_dim, bind to VAR, execute BODY, then free."
  (let ((fn-sym (gensym "FN-")))
    `(flet ((,fn-sym (,var) ,@body))
       (call-with-s-ocp-qp-dim ,n #',fn-sym))))

(defmacro with-s-ocp-qp ((var dim) &body body)
  "Allocate HPIPM ocp_qp, bind to VAR, execute BODY, then free."
  (let ((fn-sym (gensym "FN-")))
    `(flet ((,fn-sym (,var) ,@body))
       (call-with-s-ocp-qp ,dim #',fn-sym))))

