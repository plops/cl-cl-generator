;; --- Single-precision call-with-* allocation helpers ---
(defun call-with-s-ocp-qp-dim (n fn)
  "Allocate Single-precision ocp_qp_dim, call FN with struct pointer, then free."
  (let* ((mem-size (s-ocp-qp-dim-memsize n))
         (backing (cffi:foreign-alloc :char :count (+ mem-size 64)))
         (aligned-backing (align-pointer backing 64))
         (ptr (cffi:foreign-alloc :char :count (+ +hpipm-struct-size+ 64)))
         (aligned-ptr (align-pointer ptr 64)))
    (s-ocp-qp-dim-create n aligned-ptr aligned-backing)
    (unwind-protect (funcall fn aligned-ptr)
      (cffi-sys:foreign-free ptr)
      (cffi-sys:foreign-free backing))))

(defun call-with-s-ocp-qp (dim fn)
  "Allocate Single-precision ocp_qp, call FN with struct pointer, then free."
  (let* ((mem-size (s-ocp-qp-memsize dim))
         (backing (cffi:foreign-alloc :char :count (+ mem-size 64)))
         (aligned-backing (align-pointer backing 64))
         (ptr (cffi:foreign-alloc :char :count (+ +hpipm-struct-size+ 64)))
         (aligned-ptr (align-pointer ptr 64)))
    (s-ocp-qp-create dim aligned-ptr aligned-backing)
    (unwind-protect (funcall fn aligned-ptr)
      (cffi-sys:foreign-free ptr)
      (cffi-sys:foreign-free backing))))

