;; --- Single-precision solution getter wrappers ---
(defun s-ocp-qp-sol-get-u (stage n sol)
  "Optimal inputs N is the number of elements to retrieve."
  (let ((ptr (cffi:foreign-alloc :float :count n)))
    (unwind-protect (progn
                      (s-ocp-qp-sol-get "u" stage sol ptr)
                      (let ((result (make-array n :element-type 'single-float)))
                        (dotimes (i n)
                          (setf (aref result i) (cffi:mem-aref ptr :float i)))
                        result))
      (cffi-sys:foreign-free ptr))))

