;; --- Single-precision QP data setter wrappers ---
(defun s-ocp-qp-set-a (stage value qp)
  "Dynamics matrix A_k (state to state)"
  (let* ((rows (array-dimension value 0)) (cols (array-dimension value 1))
         (ptr (cffi:foreign-alloc :float :count (* rows cols))))
    (unwind-protect (progn
                      (dotimes (j cols)
                        (dotimes (i rows)
                          (setf (cffi:mem-aref ptr :float (+ (* j rows) i))
                                  (coerce (aref value i j) 'single-float))))
                      (s-ocp-qp-set "A" stage ptr qp))
      (cffi-sys:foreign-free ptr))))

