                        (ecase prec
                          (:double (d-ocp-qp-sol-get-su k ns sol))
                          (:single (s-ocp-qp-sol-get-su k ns sol)))
                        #()))))
          (values u-traj x-traj status iterations sl-traj su-traj)))))
