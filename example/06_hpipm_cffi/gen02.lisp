                    (ecase prec
                      (:double (d-ocp-qp-sol-get-u k nu sol))
                      (:single (s-ocp-qp-sol-get-u k nu sol))))))
          (dotimes (k (+ N 1))
            (let ((nx (elt nx-list k)))
              (setf (aref x-traj k)
                    (ecase prec
                      (:double (d-ocp-qp-sol-get-x k nx sol))
                      (:single (s-ocp-qp-sol-get-x k nx sol))))))
          (dotimes (k (+ N 1))
