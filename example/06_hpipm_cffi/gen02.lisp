          (:single
           (s-ocp-qp-ipm-solve qp sol arg ws)))
        (let ((status (ecase prec
                        (:double (d-ocp-qp-ipm-get-status-val ws))
                        (:single (s-ocp-qp-ipm-get-status-val ws))))
              (iterations (ecase prec
                            (:double (d-ocp-qp-ipm-get-iter-val ws))
                            (:single (s-ocp-qp-ipm-get-iter-val ws))))
              (u-traj (make-array N))
              (x-traj (make-array (+ N 1)))
              (sl-traj (make-array (+ N 1)))
              (su-traj (make-array (+ N 1))))
          (dotimes (k N)
            (let ((nu (elt nu-list k)))
