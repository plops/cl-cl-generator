              (setf (aref sl-traj k)
                    (if (> ns 0)
                        (ecase prec
                          (:double (d-ocp-qp-sol-get-sl k ns sol))
                          (:single (s-ocp-qp-sol-get-sl k ns sol)))
                        #()))
              (setf (aref su-traj k)
